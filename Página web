<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panadería M Y C - Pan y Tortas Caseras</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #f9f9f9; color: #333; }
    header { background: #b71c1c; color: white; padding: 1rem; text-align: center; }
    .hero { background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://source.unsplash.com/random/1600x900/?bakery'); background-size: cover; height: 60vh; display: flex; align-items: center; justify-content: center; color: white; text-align: center; }
    .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    .productos { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin: 3rem 0; }
    .card { background: white; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); overflow: hidden; text-align: center; padding-bottom: 1rem; }
    .card img { width: 100%; height: 200px; object-fit: cover; }
    button { background: #b71c1c; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-size: 1rem; }
    button:hover { background: #d32f2f; }
    .quantity { display: flex; align-items: center; justify-content: center; gap: 10px; margin: 10px 0; }
    .quantity input { width: 60px; text-align: center; padding: 5px; font-size: 1rem; }
    .pedido { background: #fff; padding: 2rem; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); margin: 3rem 0; }
    #map { height: 400px; border-radius: 10px; margin: 2rem 0; }
    
    .payment-options { display: flex; gap: 10px; flex-wrap: wrap; margin: 15px 0; }
    .payment-btn {
      padding: 12px 20px;
      border: 2px solid #ddd;
      background: white;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
    }
    .payment-btn.active {
      background: #b71c1c;
      color: white;
      border-color: #b71c1c;
    }
    .total { font-size: 1.4rem; font-weight: bold; color: #b71c1c; margin: 15px 0; }
  </style>
</head>
<body>

  <header>
    <h1>🍞 Panadería M Y C</h1>
    <p>Pan y tortas caseras • Entregas rápidas</p>
  </header>

  <section class="hero">
    <div>
      <h2>¡Pan y tortas caseras con el mejor sabor!</h2>
      <p>Realizamos pedidos y entregas el mismo día</p>
      <a href="#pedir"><button style="font-size:1.2rem; padding:15px 30px;">Hacer Pedido Ahora</button></a>
    </div>
  </section>

  <div class="container">

    <h2 id="productos">Nuestros Productos</h2>
    <div class="productos">
      <div class="card">
        <img src="https://source.unsplash.com/random/300x200/?bread" alt="Panes Caseros">
        <h3>Panes Caseros</h3>
        <p><strong>$2.100 la pieza</strong></p>
        <div class="quantity">
          <button onclick="cambiarCantidad(this, -1)">–</button>
          <input type="number" value="1" min="1" id="cant-pan">
          <button onclick="cambiarCantidad(this, 1)">+</button>
        </div>
        <button onclick="agregarAlCarrito('Pan Casero', 2100, 'cant-pan')">Agregar al pedido</button>
      </div>

      <div class="card">
        <img src="https://source.unsplash.com/random/300x200/?cake" alt="Torta de Chicharrón">
        <h3>Torta Casera de Chicharrón</h3>
        <p><strong>$450 c/u</strong><br>Media docena $2.700 • Docena $5.400</p>
        <div class="quantity">
          <button onclick="cambiarCantidad(this, -1)">–</button>
          <input type="number" value="1" min="1" id="cant-torta1">
          <button onclick="cambiarCantidad(this, 1)">+</button>
        </div>
        <button onclick="agregarAlCarrito('Torta de Chicharrón', 450, 'cant-torta1')">Agregar al pedido</button>
      </div>

      <div class="card">
        <img src="https://source.unsplash.com/random/300x200/?cake" alt="Torta sin Chicharrón">
        <h3>Torta Casera sin Chicharrón</h3>
        <p><strong>$450 c/u</strong><br>Media docena $2.700 • Docena $5.400</p>
        <div class="quantity">
          <button onclick="cambiarCantidad(this, -1)">–</button>
          <input type="number" value="1" min="1" id="cant-torta2">
          <button onclick="cambiarCantidad(this, 1)">+</button>
        </div>
        <button onclick="agregarAlCarrito('Torta sin Chicharrón', 450, 'cant-torta2')">Agregar al pedido</button>
      </div>

      <div class="card">
        <img src="https://source.unsplash.com/random/300x200/?pastry" alt="Raspadas">
        <h3>Raspadas</h3>
        <p><strong>$450 c/u</strong><br>Media docena $2.700 • Docena $5.400</p>
        <div class="quantity">
          <button onclick="cambiarCantidad(this, -1)">–</button>
          <input type="number" value="1" min="1" id="cant-raspadas">
          <button onclick="cambiarCantidad(this, 1)">+</button>
        </div>
        <button onclick="agregarAlCarrito('Raspadas', 450, 'cant-raspadas')">Agregar al pedido</button>
      </div>
    </div>

    <section class="pedido" id="pedir">
      <h2>Tu Pedido</h2>
      <textarea id="productosLista" rows="6" style="width:100%; padding:10px;" readonly></textarea>
      
      <div class="total" id="totalCarrito">Total: $0</div>

      <label>Método de Pago:</label><br>
      <div class="payment-options">
        <button type="button" class="payment-btn" onclick="seleccionarPago(this)" data-pago="Efectivo">💵 Efectivo</button>
        <button type="button" class="payment-btn" onclick="seleccionarPago(this)" data-pago="Mercado Pago">💳 Mercado Pago</button>
        <button type="button" class="payment-btn" onclick="seleccionarPago(this)" data-pago="Nequi / Daviplata">📱 Nequi / Daviplata</button>
        <button type="button" class="payment-btn" onclick="seleccionarPago(this)" data-pago="Otro">Otro</button>
      </div>
      <input type="hidden" id="metodoPago" value="">

      <button type="button" onclick="enviarPedido()" style="margin-top:15px; width:100%; padding:15px;">Enviar Pedido por WhatsApp</button>
    </section>

    <h2>Dónde estamos</h2>
    <div id="map"></div>
    <p><strong>Dirección:</strong> Coloca aquí tu dirección completa</p>

  </div>

  <script>
    let carrito = [];
    let metodoPagoSeleccionado = "";

    function cambiarCantidad(btn, cambio) {
      const input = btn.parentElement.querySelector('input');
      let valor = parseInt(input.value);
      valor = Math.max(1, valor + cambio);
      input.value = valor;
    }

    function agregarAlCarrito(nombre, precio, inputId) {
      const cantidad = parseInt(document.getElementById(inputId).value);
      const subtotal = precio * cantidad;
      
      carrito.push({ nombre, cantidad, precio, subtotal });
      actualizarCarrito();
      
      alert(`${cantidad} × ${nombre} agregado ✅`);
    }

    function actualizarCarrito() {
      let texto = "";
      let total = 0;

      carrito.forEach(item => {
        texto += `${item.cantidad} × ${item.nombre} = $${item.subtotal}\n`;
        total += item.subtotal;
      });

      document.getElementById("productosLista").value = texto || "Carrito vacío";
      document.getElementById("totalCarrito").textContent = `Total: $${total}`;
    }

    function seleccionarPago(btn) {
      document.querySelectorAll('.payment-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      metodoPagoSeleccionado = btn.getAttribute('data-pago');
      document.getElementById('metodoPago').value = metodoPagoSeleccionado;
    }

    function enviarPedido() {
      const nombre = document.getElementById("nombre") ? document.getElementById("nombre").value : "";
      const telefono = document.getElementById("telefono") ? document.getElementById("telefono").value : "";
      const direccion = document.getElementById("direccion") ? document.getElementById("direccion").value : "";
      const pago = metodoPagoSeleccionado || "No especificado";

      if (!nombre || !telefono || !direccion) {
        alert("Por favor completa Nombre, Teléfono y Dirección");
        return;
      }

      let productosTexto = "";
      let total = 0;

      carrito.forEach(item => {
        productosTexto += `${item.cantidad} × ${item.nombre} = $${item.subtotal}\n`;
        total += item.subtotal;
      });

      const mensaje = `🛒 *Nuevo Pedido - Panadería M Y C*%0A%0A` +
                      `👤 Nombre: ${nombre}%0A` +
                      `📞 Teléfono: ${telefono}%0A` +
                      `📍 Dirección: ${direccion}%0A%0A` +
                      `🛍️ Productos:%0A${productosTexto}%0A` +
                      `💰 Total: *$${total}*%0A` +
                      `💳 Método de pago: *${pago}*`;

      window.open(`https://wa.me/542634214771?text=${mensaje}`, "_blank");
    }

    // Mapa
    function initMap() {
      const ubicacion = { lat: -33.2950, lng: -66.3350 };
      const map = new google.maps.Map(document.getElementById("map"), {
        zoom: 15,
        center: ubicacion,
      });
      new google.maps.Marker({ position: ubicacion, map: map, title: "Panadería M Y C" });
    }
  </script>

  <script async src="https://maps.googleapis.com/maps/api/js?key=TU_API_KEY&callback=initMap"></script>

</body>
</html>
